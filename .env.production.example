NODE_ENV=production
NEXT_PUBLIC_SITE_NAME=<site-name>
DOMAIN=<example.com>
SITE_URL=<https://example.com>
NEXT_PUBLIC_SITE_URL=<https://example.com>
CDN_URL=<https://cdn.example.com>

DB_PROVIDER=postgres
DATABASE_URL=<postgresql-connection-string>
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<postgres-password>
POSTGRES_DB=<postgres-database>

ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<strong-admin-password>
COOKIE_SECRET=<64-random-characters>
ADMIN_SESSION_SECRET=<64-random-characters>
ANALYTICS_SALT=<64-random-characters>
ANALYTICS_HASH_SALT=<64-random-characters>

DEFAULT_TIKTOK_PROVIDER=<tiktok-provider-key>
DEFAULT_INSTAGRAM_PROVIDER=<instagram-provider-key>
TIKTOK_PROVIDER_API_KEY=<tiktok-provider-api-key>
INSTAGRAM_PROVIDER_API_KEY=<instagram-provider-api-key>
INSTAGRAM_FALLBACK_API_URL=<instagram-fallback-api-url>
INSTAGRAM_COOKIE=<instagram-cookie>
INSTAGRAM_APP_ID=<instagram-app-id>

CACHE_DRIVER=memory
REDIS_URL=<redis-url>
DOWNLOAD_CACHE_TTL_SECONDS=604800
RATE_LIMIT_PER_HOUR=80

GOOGLE_SITE_VERIFICATION=<google-search-console-token>
NEXT_PUBLIC_GA_MEASUREMENT_ID=<google-analytics-measurement-id>
CLOUDFLARE_TURNSTILE_SITE_KEY=<turnstile-site-key>
CLOUDFLARE_TURNSTILE_SECRET_KEY=<turnstile-secret-key>
LEGAL_CONTACT_EMAIL=<legal-contact-email>
